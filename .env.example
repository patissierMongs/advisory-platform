# 운영 기본값: 샘플 seed/feed 자동 적재 없음
ADVISORY_SEED=false
ADVISORY_BUNDLED_FEEDS=false

# SQLite 파일 위치를 바꿔야 할 때만 지정
# ADVISORY_DATA_DIR=C:\advisory-platform-data
# ADVISORY_DATABASE_URL=sqlite:///C:/advisory-platform-data/advisory.db

# SMTP 메일 발송
ADVISORY_MAIL_ENABLED=true
ADVISORY_MAIL_SMTP_HOST=smtp.internal.example
ADVISORY_MAIL_SMTP_PORT=25
ADVISORY_MAIL_USE_TLS=false
ADVISORY_MAIL_FROM=security-advisory@example.go.kr

# 인증이 필요한 SMTP일 때만 설정
# ADVISORY_MAIL_SMTP_USER=security-advisory@example.go.kr
# ADVISORY_MAIL_SMTP_PASSWORD=change-me

# 선택 채널
ADVISORY_MESSENGER_ENABLED=false
ADVISORY_GROUPWARE_ENABLED=false

# 업로드 제한
ADVISORY_MAX_UPLOAD_MB=30
